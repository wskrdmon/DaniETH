# =====================================================
# Configuración del backend DANI-ETH
# Copiar este archivo a .env y completar los valores
# =====================================================

# --- Aplicación ---
APP_NAME=DANI-ETH Backend
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Firebase ---
# Path al archivo de credenciales del Service Account
FIREBASE_CREDENTIALS_PATH=./credentials/firebase-admin-key.json
FIREBASE_PROJECT_ID=gestion-f83ec

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Gemini (lo configura el compañero a cargo del orquestador) ---
# GEMINI_API_KEY=tu_api_key_de_gemini_aquí
GEMINI_MODEL=gemini-1.5-flash
